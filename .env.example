# Copy to .env.local at the repo root (loaded by both apps via bun).
# Each app also accepts an apps/<app>/.env.local if you want app-scoped overrides.

# ──────────────────────────────────────────────────────────────
# Web app (apps/web)  — Next.js
# ──────────────────────────────────────────────────────────────

# Clerk (https://dashboard.clerk.com). Free tier is fine for local.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

# Public URL the browser uses to reach the game server WS.
NEXT_PUBLIC_GAME_SERVER_URL=ws://localhost:8787

# ──────────────────────────────────────────────────────────────
# Game server (apps/server-go)  — Go WebSocket server
# ──────────────────────────────────────────────────────────────

# Port the game server binds to.
GAME_SERVER_PORT=8787

# MongoDB connection string. Local docker compose default below.
MONGODB_URI=mongodb://localhost:27017/chesstalk

# Clerk (server-side JWT verification of WS connections).
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
CLERK_ISSUER=https://your-clerk-domain
# Optional: comma-separated values if configured in Clerk.
CLERK_AUDIENCE=
CLERK_AUTHORIZED_PARTIES=http://localhost:3000

# Deepgram — speech-to-text. Optional for local dev; if blank, the
# server falls back to relying on the browser's Web Speech API.
# Get a key at https://console.deepgram.com (free $200 credit).
DEEPGRAM_API_KEY=

# Stockfish executable used for bot games. Leave as "stockfish" if it is
# installed on PATH, or set an absolute path to your Stockfish binary.
STOCKFISH_PATH=stockfish

# Comma-separated list of origins allowed to open WS connections.
ALLOWED_ORIGINS=http://localhost:3000
